# RapidAPI Configuration
# Get your API key from: https://rapidapi.com/hub
VITE_RAPIDAPI_API_KEY=your_rapidapi_key_here

# Firebase Configuration
# Get these values from your Firebase project settings
# Firebase Console -> Project Settings -> General -> Your apps -> SDK setup and configuration
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id

# Instructions:
# 1. Copy this file to .env.local for local development
# 2. Replace all values with your actual credentials
# 3. Never commit .env.local to git (it's already in .gitignore)
# 4. For GitHub Actions deployment, add these as GitHub Secrets (see SETUP_GITHUB_SECRETS.md)

# Notes:
# - All environment variables must be prefixed with VITE_ to be accessible in the application
# - Firebase API keys are meant to be public but should still be configured via environment variables
# - Keep your RapidAPI key secret and never commit it to source control
VITE_TOURNAMENT_PASSWORD=FantasyGolf2026!